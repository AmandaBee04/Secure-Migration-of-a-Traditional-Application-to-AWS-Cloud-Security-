# terraform.tfvars.example
# Copy to terraform.tfvars and fill in the values.
# DO NOT commit terraform.tfvars to Git — it contains secrets.

aws_region     = "ap-southeast-1"
project_name   = "sms"
environment    = "production"
db_name        = "sms_db"
db_username    = "sms_admin"

# Set these as environment variables instead:
# export TF_VAR_db_password="your_strong_password_here"
# export TF_VAR_password_pepper="your_random_pepper_here"

# Fill in after pushing Docker images to ECR (see AWS guide):
backend_image  = "123456789.dkr.ecr.ap-southeast-1.amazonaws.com/sms-backend:latest"
frontend_image = "123456789.dkr.ecr.ap-southeast-1.amazonaws.com/sms-frontend:latest"
